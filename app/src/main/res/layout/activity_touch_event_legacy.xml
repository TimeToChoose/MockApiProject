<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击分发与滑动冲突"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="传统 View 事件机制学习"
            android:textColor="#666666"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="点击事件分发"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="观察父子容器事件顺序与 onClick 触发"
            android:textColor="#666666"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/parentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="父容器触发次数: 0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/childCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="子元素 onClick 次数: 0"
            android:textSize="14sp" />

        <com.shineofeidos.mockapiproject.ui.customview.EventDispatchParentLayout
            android:id="@+id/eventParent"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:background="#ECEFF1"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp">

            <com.shineofeidos.mockapiproject.ui.customview.EventDispatchChildView
                android:id="@+id/eventChild"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:background="#D1C4E9"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="子元素"
                android:textColor="#212121"
                android:textSize="18sp" />
        </com.shineofeidos.mockapiproject.ui.customview.EventDispatchParentLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/clearLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清空日志" />

            <Button
                android:id="@+id/guideButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="查看指南" />
        </LinearLayout>

        <TextView
            android:id="@+id/eventLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:text="暂无事件"
            android:textColor="#333333"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="滑动冲突处理"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="在竖向滚动中嵌入横向滑动区域"
            android:textColor="#666666"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="智能拦截"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/switchSmart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:checked="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/parentScrollState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="父级滚动: 已启用"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/gestureState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="当前手势: 未检测"
            android:textSize="14sp" />

        <com.shineofeidos.mockapiproject.ui.customview.SmartHorizontalScrollView
            android:id="@+id/horizontalScroll"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="12dp"
            android:background="#ECEFF1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="12dp"
                    android:background="#BBDEFB"
                    android:gravity="center"
                    android:text="卡片 1" />

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="12dp"
                    android:background="#BBDEFB"
                    android:gravity="center"
                    android:text="卡片 2" />

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="12dp"
                    android:background="#BBDEFB"
                    android:gravity="center"
                    android:text="卡片 3" />

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="12dp"
                    android:background="#BBDEFB"
                    android:gravity="center"
                    android:text="卡片 4" />

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="12dp"
                    android:background="#BBDEFB"
                    android:gravity="center"
                    android:text="卡片 5" />

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="12dp"
                    android:background="#BBDEFB"
                    android:gravity="center"
                    android:text="卡片 6" />
            </LinearLayout>
        </com.shineofeidos.mockapiproject.ui.customview.SmartHorizontalScrollView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="水平拖动卡片区域，观察父级滚动状态变化"
            android:textColor="#666666"
            android:textSize="13sp" />

        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="返回" />
    </LinearLayout>
</ScrollView>
